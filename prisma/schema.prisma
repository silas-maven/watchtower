generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER

  @@map("watchtower_spa_role")
}

enum SubscriptionStatus {
  ACTIVE
  OVERDUE
  PAUSED
  REMOVED

  @@map("watchtower_spa_subscription_status")
}

enum AccessState {
  ACTIVE
  PAUSED
  REMOVED

  @@map("watchtower_spa_access_state")
}

enum BillingAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED

  @@map("watchtower_spa_billing_alert_status")
}

enum UsageEventType {
  SIGN_IN
  PAGE_VIEW
  ASSET_VIEW
  WATCHLIST_ADD
  WATCHLIST_REMOVE
  ALERT_OPEN
  AI_BRIEF_GENERATE
  AVERAGE_PLAN_CREATE
  DUE_DILIGENCE_UPDATE

  @@map("watchtower_spa_usage_event_type")
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
  COMMODITY
  FOREX
  INDEX
  REIT
  OTHER

  @@map("watchtower_spa_asset_type")
}

enum AiReportKind {
  PITCH
  STRESS_TEST
  PERSONAL_FINANCE

  @@map("watchtower_spa_ai_report_kind")
}

enum SignalState {
  NONE
  BUY
  SELL
  BOTH

  @@map("watchtower_spa_signal_state")
}

enum SignalEventType {
  ENTER_BUY
  EXIT_BUY
  ENTER_SELL
  EXIT_SELL
  ENTER_BOTH
  EXIT_BOTH

  @@map("watchtower_spa_signal_event_type")
}

enum SignalOverride {
  FORCE_BUY
  FORCE_SELL
  SUPPRESS

  @@map("watchtower_spa_signal_override")
}

enum PortfolioKind {
  REAL
  VIRTUAL

  @@map("watchtower_spa_portfolio_kind")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(MEMBER)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions      Session[]
  subscription  Subscription?
  watches       PersonalWatch[]
  notifications Notification[]

  @@map("watchtower_spa_users")
}

model Profile {
  id                   String      @id @default(cuid())
  clerkUserId          String      @unique
  email                String      @unique
  name                 String
  role                 Role        @default(MEMBER)
  accessState          AccessState @default(ACTIVE)
  accessNote           String?
  baseCurrency         String      @default("GBP")
  declaredPortfolioGBP Float?
  averageInvestmentGBP Float?
  lastSeenAt           DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  stripeCustomer         StripeCustomer?
  subscriptionMirror     SubscriptionMirror?
  portfolios             UserPortfolio[]
  watchlists             UserWatchlist[]
  holdings               UserHolding[]
  averagePlans           AveragePlan[]
  dueDiligenceRecords    DueDiligenceRecord[]
  closedPositions        ClosedPosition[]
  usageEvents            UsageEvent[]
  notifications          Notification[]
  billingAlerts          BillingAlert[]
  accessActions          AdminAccessAction[]  @relation("AdminAccessTarget")
  performedAccessActions AdminAccessAction[]  @relation("AdminAccessActor")
  assetActions           AdminAssetAction[]   @relation("AdminAssetActor")
  aiReports              AiReport[]
  personalFinance        PersonalFinanceInput?
  stockRequests          StockRequest[]

  @@index([role, accessState])
  @@index([lastSeenAt(sort: Desc)])
  @@map("watchtower_spa_profiles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("watchtower_spa_sessions")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  status                SubscriptionStatus @default(ACTIVE)
  dueAt                 DateTime?
  lastPaidAt            DateTime?
  pausedAt              DateTime?
  removedAt             DateTime?
  overdueStage          Int                @default(0)
  lastOverdueNotifiedAt DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("watchtower_spa_subscriptions")
}

model StripeCustomer {
  id               String   @id @default(cuid())
  profileId        String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("watchtower_spa_stripe_customers")
}

model SubscriptionMirror {
  id                   String             @id @default(cuid())
  profileId            String             @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(ACTIVE)
  stripeStatus         String?
  currentPeriodEnd     DateTime?
  lastPaidAt           DateTime?
  lastPaymentFailedAt  DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])
  @@map("watchtower_spa_subscription_mirrors")
}

model PaymentEvent {
  id             String   @id @default(cuid())
  stripeEventId  String   @unique
  stripeObjectId String?
  type           String
  profileId      String?
  amount         Int?
  currency       String?
  status         String?
  payload        Json?
  createdAt      DateTime @default(now())

  @@index([profileId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("watchtower_spa_payment_events")
}

model BillingAlert {
  id            String             @id @default(cuid())
  profileId     String?
  type          String
  title         String
  body          String
  status        BillingAlertStatus @default(OPEN)
  stripeEventId String?
  metadata      Json?
  createdAt     DateTime           @default(now())
  resolvedAt    DateTime?

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([profileId, createdAt(sort: Desc)])
  @@map("watchtower_spa_billing_alerts")
}

model Asset {
  id          String    @id @default(cuid())
  symbol      String    @unique
  quoteSymbol String?
  name        String
  reason      String?
  assetType   AssetType @default(STOCK)
  currency    String    @default("USD")
  sourceRow   Int?

  brokerEntryPrice  Float?
  averageEntryPrice Float?
  shares            Float?

  currentCostGBP  Float?
  currentValueGBP Float?
  weightPct       Float?
  returnPct       Float?

  beta      Float?
  low52     Float?
  high52    Float?
  volumeAvg Float?
  pe        Float?
  dataDelay Float?
  marketCap Float?

  ma50          Float?
  ma200         Float?
  dividendYield Float?
  quickRatio    Float?
  currentRatio  Float?
  debtToEquity  Float?
  // Admin-entered until a sector P/E data source is wired in.
  sectorPE      Float?
  fundamentalsAt DateTime?

  nextEarningsDate DateTime?

  closeYest Float?
  tags      Json?
  // Macro instruments (indices, FX, commodities) power the ticker strip and
  // Weather Outside; they are excluded from member watchlist/library tables.
  isMacro   Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rule                AssetRule?
  snapshots           AssetSnapshot[]
  signalEvents        SignalEvent[]
  watches             PersonalWatch[]
  watchlistItems      UserWatchlistItem[]
  holdings            UserHolding[]
  averagePlans        AveragePlan[]
  dueDiligenceRecords DueDiligenceRecord[]
  closedPositions     ClosedPosition[]
  assetActions        AdminAssetAction[]
  aiReports           AiReport[]

  @@map("watchtower_spa_assets")
}

model AssetRule {
  id          String   @id @default(cuid())
  assetId     String   @unique
  targetEntry Float?
  targetExit  Float?
  note        String?

  signalOverride  SignalOverride?
  overrideNote    String?
  overrideSetAt   DateTime?
  overrideSetById String?

  updatedAt   DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("watchtower_spa_asset_rules")
}

model AssetSnapshot {
  id             String   @id @default(cuid())
  assetId        String
  capturedAt     DateTime @default(now())
  currentPrice   Float?
  dailyChangePct Float?
  dailyChange    Float?
  dailyHigh      Float?
  dailyLow       Float?
  closeYest      Float?

  beta      Float?
  low52     Float?
  high52    Float?
  volumeAvg Float?
  pe        Float?
  dataDelay Float?
  marketCap Float?

  signalState SignalState @default(NONE)
  source      String?
  fetchError  String?
  raw         Json?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, capturedAt(sort: Desc)])
  @@map("watchtower_spa_asset_snapshots")
}

model SignalEvent {
  id         String          @id @default(cuid())
  assetId    String
  eventType  SignalEventType
  fromState  SignalState
  toState    SignalState
  occurredAt DateTime        @default(now())
  metadata   Json?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, occurredAt(sort: Desc)])
  @@index([occurredAt(sort: Desc)])
  @@map("watchtower_spa_signal_events")
}

model PersonalWatch {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
  @@index([userId])
  @@map("watchtower_spa_personal_watches")
}

model UserPortfolio {
  id                String        @id @default(cuid())
  profileId         String
  name              String        @default("Main Portfolio")
  kind              PortfolioKind @default(REAL)
  declaredValueGBP  Float?
  investedAmountGBP Float?
  cashAmountGBP     Float?

  budgetPerStockGBP   Float?
  minEntryGBP         Float?
  targetHoldingsCount Int?

  measuredAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  profile  Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  holdings UserHolding[]

  @@index([profileId, measuredAt(sort: Desc)])
  @@index([profileId, kind])
  @@map("watchtower_spa_user_portfolios")
}

model UserHolding {
  id              String   @id @default(cuid())
  profileId       String
  assetId         String
  portfolioId     String?
  shares          Float?
  averagePrice    Float?
  investedGBP     Float?
  currentValueGBP Float?
  note            String?
  spartanEnabled     Boolean  @default(true)
  averagePlanId      String?  @unique
  manualNextBuyPrice Float?
  manualSellTarget   Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile     Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  asset       Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  portfolio   UserPortfolio? @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  averagePlan AveragePlan?   @relation(fields: [averagePlanId], references: [id], onDelete: SetNull)

  @@unique([profileId, assetId, portfolioId])
  @@index([assetId])
  @@index([portfolioId])
  @@map("watchtower_spa_user_holdings")
}

model UserWatchlist {
  id        String   @id @default(cuid())
  profileId String
  name      String   @default("My Watchlist")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  items   UserWatchlistItem[]

  @@unique([profileId, name])
  @@index([profileId, isDefault])
  @@map("watchtower_spa_user_watchlists")
}

model UserWatchlistItem {
  id          String   @id @default(cuid())
  watchlistId String
  assetId     String
  createdAt   DateTime @default(now())

  watchlist UserWatchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, assetId])
  @@index([assetId])
  @@map("watchtower_spa_user_watchlist_items")
}

model AveragePlan {
  id                     String   @id @default(cuid())
  profileId              String
  assetId                String
  currency               String
  tradeOneGBP            Float?
  tradeTwoGBP            Float?
  tradeThreeGBP          Float?
  tradeFourGBP           Float?
  targetPriceOne         Float?
  targetPriceTwo         Float?
  targetPriceThree       Float?
  targetPriceFour        Float?
  calculatedAveragePrice Float?
  calculatedShares       Float?
  basePrice              Float?
  targetSellPrice        Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  profile  Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  asset    Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tranches AveragePlanTranche[]
  holding  UserHolding?

  @@index([profileId, createdAt(sort: Desc)])
  @@index([assetId])
  @@map("watchtower_spa_average_plans")
}

model AveragePlanTranche {
  id         String    @id @default(cuid())
  planId     String
  orderIndex Int
  price      Float
  budgetGBP  Float?
  executed   Boolean   @default(false)
  executedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  plan AveragePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, orderIndex])
  @@index([planId])
  @@map("watchtower_spa_average_plan_tranches")
}

model DueDiligenceRecord {
  id        String   @id @default(cuid())
  profileId String
  assetId   String
  checklist Json
  notes     String?
  score     Int?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([profileId, assetId])
  @@index([assetId])
  @@map("watchtower_spa_due_diligence_records")
}

model UsageEvent {
  id        String         @id @default(cuid())
  profileId String?
  type      UsageEventType
  path      String?
  metadata  Json?
  createdAt DateTime       @default(now())

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@map("watchtower_spa_usage_events")
}

model AnalyticsRollup {
  id         String   @id @default(cuid())
  rollupDate DateTime
  key        String
  value      Float
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([rollupDate, key])
  @@index([key, rollupDate(sort: Desc)])
  @@map("watchtower_spa_analytics_rollups")
}

model DailyBrief {
  id          String   @id @default(cuid())
  briefDate   DateTime
  timezone    String
  summary     String
  buy         Json
  sell        Json
  newToday    Json
  droppedOff  Json
  insights    Json
  model           String
  isFallback      Boolean  @default(false)
  generationError String?
  generatedAt     DateTime @default(now())

  @@unique([briefDate, timezone])
  @@index([briefDate(sort: Desc)])
  @@map("watchtower_spa_daily_briefs")
}

model WeeklyDigest {
  id              String   @id @default(cuid())
  weekStart       DateTime
  timezone        String
  summary         String
  sections        Json
  model           String
  isFallback      Boolean  @default(false)
  generationError String?
  generatedAt     DateTime @default(now())

  @@unique([weekStart, timezone])
  @@index([weekStart(sort: Desc)])
  @@map("watchtower_spa_weekly_digests")
}

// Persisted output of the AI tools (pitch generator, portfolio stress test,
// personal finance analysis). `inputs` captures the deterministic context the
// model narrated so results stay auditable.
model AiReport {
  id        String       @id @default(cuid())
  kind      AiReportKind
  profileId String?
  assetId   String?
  inputs    Json
  result    Json
  model     String?
  createdAt DateTime     @default(now())

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)
  asset   Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([profileId, kind, createdAt(sort: Desc)])
  @@index([assetId, kind, createdAt(sort: Desc)])
  @@map("watchtower_spa_ai_reports")
}

// Member-entered inputs for the personal finance (CFO) tool. One row per member.
model PersonalFinanceInput {
  id               String   @id @default(cuid())
  profileId        String   @unique
  age              Int?
  monthlyIncome    Float?
  monthlyExpenses  Float?
  savings          Float?
  investments      Float?
  pension          Float?
  debts            Json?
  homeValue        Float?
  monthlyInvesting Float?
  goal             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("watchtower_spa_personal_finance_inputs")
}

// Member-submitted request to add a stock to the academy universe. Reviewed by
// an admin (status PENDING -> REVIEWED / ADDED / DECLINED).
model StockRequest {
  id        String   @id @default(cuid())
  profileId String
  symbol    String
  note      String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@index([profileId])
  @@map("watchtower_spa_stock_requests")
}

model PlatformSetting {
  key         String   @id
  value       Json
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("watchtower_spa_platform_settings")
}

model JobRun {
  id         String    @id @default(cuid())
  job        String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  stats      Json?
  error      String?

  @@index([job, startedAt(sort: Desc)])
  @@map("watchtower_spa_job_runs")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  profileId String?
  role      Role?
  type      String
  title     String
  body      String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([profileId, createdAt(sort: Desc)])
  @@index([role, createdAt(sort: Desc)])
  @@map("watchtower_spa_notifications")
}

model AdminAccessAction {
  id              String       @id @default(cuid())
  targetProfileId String
  actorProfileId  String?
  fromState       AccessState?
  toState         AccessState
  reason          String?
  createdAt       DateTime     @default(now())

  targetProfile Profile  @relation("AdminAccessTarget", fields: [targetProfileId], references: [id], onDelete: Cascade)
  actorProfile  Profile? @relation("AdminAccessActor", fields: [actorProfileId], references: [id], onDelete: SetNull)

  @@index([targetProfileId, createdAt(sort: Desc)])
  @@map("watchtower_spa_admin_access_actions")
}

model AdminAssetAction {
  id             String   @id @default(cuid())
  assetId        String
  actorProfileId String?
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())

  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  actorProfile Profile? @relation("AdminAssetActor", fields: [actorProfileId], references: [id], onDelete: SetNull)

  @@index([assetId, createdAt(sort: Desc)])
  @@index([actorProfileId, createdAt(sort: Desc)])
  @@map("watchtower_spa_admin_asset_actions")
}

model MockEmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  body      String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("watchtower_spa_mock_email_logs")
}

model ImportRun {
  id         String   @id @default(cuid())
  sourceFile String
  status     String
  rowCount   Int      @default(0)
  assetCount Int      @default(0)
  notes      Json?
  createdAt  DateTime @default(now())

  @@map("watchtower_spa_import_runs")
}

model ClosedPosition {
  id                 String   @id @default(cuid())
  profileId          String
  assetId            String
  shares             Float?
  investmentValueGBP Float?
  averageEntryPrice  Float?
  exitPrice          Float?
  returnPct          Float?
  profitGBP          Float?
  reason             String?
  closedAt           DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([profileId, closedAt(sort: Desc)])
  @@index([assetId])
  @@map("watchtower_spa_closed_positions")
}
